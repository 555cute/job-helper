{
  "name": "job-helper",
  "private": true,
  "version": "1.0.0",
  "description": "求职助手桌面端：Agent 改简历 + Boss/智联岗位检索",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-ports.mjs 5173 47821",
    "dev": "concurrently -k -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:server": "node server/index.js",
    "predesktop": "node scripts/kill-ports.mjs 5173 47821",
    "desktop": "npm run build && cross-env JOB_HELPER_FORCE_DIST=1 electron .",
    "predev:desktop": "node scripts/kill-ports.mjs 5173 47821",
    "dev:desktop": "concurrently -k -n server,web,desktop -c cyan,magenta,green \"npm:dev:server\" \"npm:dev:web\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:127.0.0.1:5173 http://127.0.0.1:47821/api/health && cross-env JOB_HELPER_FORCE_DEV=1 JOB_HELPER_OPEN_DEVTOOLS=0 electron .",
    "electron": "electron .",
    "build": "tsc -b && vite build",
    "start": "npm run desktop",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "global-agent": "^4.1.3",
    "https-proxy-agent": "^9.1.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tesseract.js": "^7.0.0",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^8.0.4"
  },
  "allowScripts": {
    "electron@37.10.3": true
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.5"
  }
}
